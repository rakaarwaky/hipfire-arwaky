#!/usr/bin/env python3
"""
LocalMaxxing benchmark submission orchestrator.

Runs hipfire bench across 5 critical models × {AR, DFlash} = 10 configs,
parses results, submits to https://localmaxxing.com/api/benchmarks
serially with 310s rate-limit spacing.

Saves results to /tmp/lmx_bench_results.json before submission so a
failed POST never loses bench data.
"""
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

# ── Constants ──────────────────────────────────────────────────────────────
API_KEY = os.environ["LMX_API_KEY"]
API_URL = "https://localmaxxing.com/api/benchmarks"
RESULTS_PATH = Path("/tmp/lmx_bench_results.json")
LOG_PATH = Path("/tmp/lmx_bench_orchestrator.log")
PER_MODEL_CFG = Path.home() / ".hipfire" / "per_model_config.json"
PER_MODEL_BAK = Path("/tmp/per_model_config.bak.json")

HARDWARE = {
    "hwClass": "DISCRETE_GPU",
    "gpuName": "RX 7900 XTX",
    "gpuCount": 1,
    "vramGb": 24,
    "cpu": "AMD Ryzen 9 3900X",
    "ramGb": 64,
    "os": "Ubuntu 24.04",
}

# Worktree commit for engine version
ENGINE_VERSION = subprocess.check_output(
    ["git", "rev-parse", "--short", "HEAD"],
    cwd="/home/kaden/ClaudeCode/autorocm/hipfire/.worktrees/dflash",
    text=True,
).strip()

PROMPT = "Explain the theory of general relativity in simple terms."
RUNS = 3
MAX_SEQ = 4096

# (tag, hfId) for the 5 critical models
MODELS = [
    ("qwen3.5:9b",      "Qwen/Qwen3.5-9B"),
    ("qwen3.5:27b",     "Qwen/Qwen3.5-27B"),
    ("qwen3.5:35b-a3b", "Qwen/Qwen3.5-35B-A3B"),
    ("qwen3.6:27b",     "Qwen/Qwen3.6-27B"),
    ("qwen3.6:35b-a3b", "Qwen/Qwen3.6-35B-A3B"),
]
MODES = ["off", "on"]  # AR vs DFlash

# Per-model VRAM minima — used to size physical_cap budget headroom
MODEL_MIN_VRAM = {
    "qwen3.5:9b": 6,
    "qwen3.5:27b": 16,
    "qwen3.5:35b-a3b": 22,
    "qwen3.6:27b": 16,
    "qwen3.6:35b-a3b": 22,
}


def log(msg):
    line = f"[{time.strftime('%H:%M:%S')}] {msg}"
    print(line, flush=True)
    with LOG_PATH.open("a") as f:
        f.write(line + "\n")


def backup_per_model():
    if PER_MODEL_CFG.exists():
        PER_MODEL_BAK.write_text(PER_MODEL_CFG.read_text())
        log(f"backed up per_model_config to {PER_MODEL_BAK}")


def restore_per_model():
    if PER_MODEL_BAK.exists():
        PER_MODEL_CFG.write_text(PER_MODEL_BAK.read_text())
        log(f"restored per_model_config from {PER_MODEL_BAK}")


def patch_per_model(tag, dflash_mode):
    """Set per-model overrides for this bench run.

    cask_sidecar="" disables sidecar for clean numbers.
    max_seq=4096 keeps VRAM consistent across models.
    dflash_mode=on/off explicit; bypasses A3B auto-gate when on.
    thinking=off skips reasoning preamble.
    """
    cfg = json.loads(PER_MODEL_CFG.read_text()) if PER_MODEL_CFG.exists() else {}
    cfg[tag] = {
        "cask_sidecar": "",
        "cask": False,
        "cask_budget": 512,
        "cask_beta": 128,
        "max_seq": MAX_SEQ,
        "dflash_mode": dflash_mode,
        "thinking": "off",
    }
    PER_MODEL_CFG.write_text(json.dumps(cfg, indent=2))


def run_bench(tag):
    """Invoke `hipfire bench <tag> --runs N`. Returns (stdout+stderr, returncode)."""
    env = os.environ.copy()
    env["PATH"] = f"{Path.home() / '.hipfire' / 'bin'}:" + env.get("PATH", "")
    cmd = ["hipfire", "bench", tag, "--runs", str(RUNS), PROMPT]
    log(f"  $ {' '.join(cmd)}")
    proc = subprocess.run(
        cmd, capture_output=True, text=True, env=env, timeout=600
    )
    out = proc.stdout + proc.stderr
    return out, proc.returncode


# ── Output parsing ─────────────────────────────────────────────────────────
def parse_bench_output(output):
    """Extract perf metrics from `hipfire bench` text output."""
    def match_float(pat):
        m = re.search(pat, output)
        return float(m.group(1)) if m else None

    return {
        "decode_tokS": match_float(r"Decode\s+tok/s\s+([\d.]+)"),
        "wall_tokS": match_float(r"Wall\s+tok/s\s+([\d.]+)"),
        "ttft_ms": match_float(r"TTFT\s+ms\s+([\d.]+)"),
        "prefill_user_tokS": match_float(r"Prefill\s+tok/s\s+([\d.]+)\s+[\d.]+\s+[\d.]+\s+[\d.]+\s+\(user prompt"),
        "pp128_tokS": match_float(r"pp128\s+([\d.]+)"),
        "pp512_tokS": match_float(r"pp512\s+([\d.]+)"),
        "pp1024_tokS": match_float(r"pp1024\s+([\d.]+)"),
        "pp2048_tokS": match_float(r"pp2048\s+([\d.]+)"),
        "vram_loaded_mb": int(m.group(1)) if (m := re.search(r"vram:\s+(\d+)\s+MB loaded", output)) else None,
        "max_seq": int(m.group(1)) if (m := re.search(r"max_seq:\s+(\d+)", output)) else None,
        "dflash_disabled": "DFlash disabled" in output,
        "raw_output_tail": output[-2000:],
    }


# ── Submission ─────────────────────────────────────────────────────────────
def build_payload(tag, hfid, mode, parsed):
    """Build the localmaxxing submission JSON payload."""
    decode_mode = "DFlash" if mode == "on" else "AR"
    notes_lines = [
        f"hipfire @ {ENGINE_VERSION} (dflash branch, post-v0.1.8-alpha)",
        f"prompt: \"{PROMPT}\"",
        f"runs: {RUNS}",
        f"max_seq: {MAX_SEQ}",
        f"kv_cache: asym3 (3-bit rotated K + Q8 V; 5.5x vs fp32)",
        f"sidecar: disabled (cask_sidecar=\"\")",
        f"decode mode: {decode_mode}",
    ]
    if parsed.get("pp128_tokS"):
        notes_lines.append(f"pp128: {parsed['pp128_tokS']:.1f} tok/s")
    if parsed.get("pp512_tokS"):
        notes_lines.append(f"pp512: {parsed['pp512_tokS']:.1f} tok/s")
    if parsed.get("pp1024_tokS"):
        notes_lines.append(f"pp1024: {parsed['pp1024_tokS']:.1f} tok/s")
    if parsed.get("pp2048_tokS"):
        notes_lines.append(f"pp2048: {parsed['pp2048_tokS']:.1f} tok/s")
    if parsed.get("vram_loaded_mb"):
        notes_lines.append(f"vram_loaded: {parsed['vram_loaded_mb']} MB")
    notes = "\n".join(notes_lines)[:2000]

    payload = {
        "hfId": hfid,
        "hardware": HARDWARE,
        "engineName": "hipfire",
        "engineVersion": f"0.1.8-alpha+{ENGINE_VERSION}",
        "backend": "HIP/ROCm",
        "quantization": "MQ4",
        "tokSOut": parsed["decode_tokS"],
        "tokSTotal": parsed["wall_tokS"],
        "ttftMs": parsed["ttft_ms"],
        "promptTokens": 20,  # default prompt tokenizes to ~20 tokens
        "outputTokens": 128,
        "contextLength": parsed.get("max_seq") or MAX_SEQ,
        "batchSize": 1,
        "peakVramGb": (parsed["vram_loaded_mb"] / 1024) if parsed.get("vram_loaded_mb") else None,
        "notes": notes,
        "engineFlags": {
            "kvCache": "asym3",
            "wmma": True,
            "hipGraph": True,
        },
    }
    if mode == "on":
        payload["engineFlags"]["specDecoding"] = True
        payload["engineFlags"]["specMethod"] = "DFlash"
        payload["engineFlags"]["specBlockSize"] = 16
        payload["engineFlags"]["specModel"] = f"hipfire-{tag.replace(':', '-')}-dflash-mq4"

    payload["engineFlags"]["commandSnippet"] = (
        f"hipfire bench {tag} --runs {RUNS} \"{PROMPT}\"  "
        f"# dflash_mode={mode}, max_seq={MAX_SEQ}, kv=asym3, sidecar=off"
    )

    # Drop any None-valued top-level keys (API may reject)
    return {k: v for k, v in payload.items() if v is not None}


def submit(payload):
    """POST to localmaxxing. Returns (status_code, response_body)."""
    import urllib.request
    import urllib.error

    body = json.dumps(payload).encode()
    req = urllib.request.Request(
        API_URL,
        data=body,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {API_KEY}",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return resp.status, resp.read().decode()
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode() if e.fp else str(e)
    except Exception as e:
        return 0, f"transport error: {e}"


# ── Main ───────────────────────────────────────────────────────────────────
def main():
    LOG_PATH.write_text("")  # truncate
    log(f"=== LocalMaxxing bench orchestrator @ engine {ENGINE_VERSION} ===")
    log(f"5 models × 2 modes = 10 benches; submitting with 310s spacing")

    backup_per_model()
    results = []

    try:
        # ── Phase 1: bench all 10 configs ──
        for i, (tag, hfid) in enumerate(MODELS):
            for mode in MODES:
                idx = i * 2 + MODES.index(mode) + 1
                label = f"[{idx}/10] {tag} dflash={mode}"
                log(f"\n=== {label} ===")
                patch_per_model(tag, mode)
                t0 = time.time()
                output, rc = run_bench(tag)
                dt = time.time() - t0
                parsed = parse_bench_output(output)
                log(f"  rc={rc} dt={dt:.1f}s")
                log(f"  decode={parsed.get('decode_tokS')} ttft={parsed.get('ttft_ms')}ms wall={parsed.get('wall_tokS')}")
                if rc != 0 or not parsed.get("decode_tokS"):
                    log(f"  WARN: bench failed or no decode parsed; skipping submission")
                results.append({
                    "tag": tag,
                    "hfid": hfid,
                    "mode": mode,
                    "rc": rc,
                    "dt_s": dt,
                    "parsed": parsed,
                })
                # Save after each bench so partial progress survives
                RESULTS_PATH.write_text(json.dumps(results, indent=2))

        log(f"\n=== Phase 1 complete: bench results written to {RESULTS_PATH} ===")

        # ── Phase 2: submit, 310s rate-limit spacing ──
        submitted = []
        for i, r in enumerate(results):
            if r["rc"] != 0 or not r["parsed"].get("decode_tokS"):
                log(f"  [skip] {r['tag']} dflash={r['mode']}: bench failed")
                continue
            payload = build_payload(r["tag"], r["hfid"], r["mode"], r["parsed"])

            if submitted:
                log(f"  ...sleeping 310s for rate limit before next submission")
                time.sleep(310)

            log(f"\n=== submit [{i+1}/10] {r['tag']} dflash={r['mode']} ===")
            log(f"  hfId={payload['hfId']} tokSOut={payload['tokSOut']:.1f} ttft={payload['ttftMs']:.1f}ms")
            status, body = submit(payload)
            log(f"  HTTP {status}")
            log(f"  body: {body[:500]}")
            submitted.append({
                "request": payload,
                "status": status,
                "response": body,
            })
            (Path("/tmp/lmx_submissions.json")).write_text(json.dumps(submitted, indent=2))

        log(f"\n=== DONE: {len(submitted)} submissions, log at {LOG_PATH} ===")

    finally:
        restore_per_model()
        log("per_model_config restored. orchestrator exit.")


if __name__ == "__main__":
    main()
