#!/bin/bash
# hipfire CLI wrapper — routes to Bun CLI
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HIPFIRE_DIR="$HOME/.hipfire"

# Find the CLI
CLI=""
for candidate in "$SCRIPT_DIR/../cli/index.ts" "$HIPFIRE_DIR/cli/index.ts" "$(dirname "$SCRIPT_DIR")/cli/index.ts"; do
    if [ -f "$candidate" ]; then CLI="$candidate"; break; fi
done

if [ -z "$CLI" ]; then
    echo "hipfire CLI not found. Re-run the installer."
    exit 1
fi

exec bun run "$CLI" "$@"
